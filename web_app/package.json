{
  "name": "web_app",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "postinstall": "npm install --prefix client",
    "dev": "concurrently -n API,UI -c blue,green \"npm run dev:api\" \"npm run dev:ui\"",
    "dev:api": "nodemon --watch src --ext ts --exec \"node --no-deprecation -r ts-node/register src/index.ts\"",
    "dev:ui": "node -e \"const{execSync}=require('child_process');execSync('npm run dev',{cwd:'client',stdio:'inherit'})\"",
    "build": "tsc && npm run build --prefix client",
    "start": "node dist/index.js",
    "db:migrate": "ts-node src/db/migrate.ts",
    "db:seed": "ts-node src/db/seed.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.9.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.12",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
